    - target: {fileID: 8063609272687953924, guid: 58206228119b2ed4ab0ad31cdc8ed92c, type: 3}
      propertyPath: m_text
      value: "Since you have such a big ship, you need a lot of weapons.\r\n\r\nEach
        one is placed to cover your ship as well as it can.\r\n\r\nBut that does
        not come without a price.\r\n\r\nLet\u2019s just say the controls can get
        a little over the top, and you may need help from other operators."
      objectReference: {fileID: 0}
